# ─────────────────────────────────────────────
# CourtAccess AI — Frontend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Backend API
# Point this to the FastAPI backend once available
VITE_API_BASE_URL=http://localhost:8000

# WebSocket Base URL (optional - defaults to current host)
# Used for real-time interpretation sessions
VITE_WS_BASE=ws://localhost:8000

# ─────────────────────────────────────────────
# Firebase / Identity Platform (required)
# Get these from GCP Console → Identity Platform → Application Setup Details
# These are PUBLIC values — safe to commit to code
# ─────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ─────────────────────────────────────────────
# Auth Providers (not required for prototype)
# These are only needed when real OAuth is wired up
# Leave blank to run the UI in prototype/mock mode
# ─────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
