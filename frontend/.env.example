# ─────────────────────────────────────────────
# CourtAccess AI — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Backend API
# Point this to the FastAPI backend once available
VITE_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Auth Providers (not required for prototype)
# These are only needed when real OAuth is wired up
# Leave blank to run the UI in prototype/mock mode
# ─────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_APPLE_CLIENT_ID=

### Required for frontend 
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=