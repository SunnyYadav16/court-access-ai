# ==============================================================================
# .gitignore — court-access-ai (monorepo root)
# Single consolidated file. Do NOT add nested .gitignore files anywhere.
# ==============================================================================


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg
*.egg-info/
.installed.cfg
.eggs/
develop-eggs/
# Python build directories (using specific paths to avoid catching source folders)
/dist/
/build/
MANIFEST
/downloads/
eggs/
# Python virtual environment lib folders (not source code)
**/site-packages/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
__pypackages__/

# ── PyInstaller ───────────────────────────────────────────────────────────────
*.manifest
*.spec

# ── Installer logs ────────────────────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.Python
.pixi/
.pdm-python
.pdm-build/

# ── Tests & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
*.cover
*.py.cover
.hypothesis/
cover/

# ── Type checkers & linters ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ── Notebooks ────────────────────────────────────────────────────────────────
.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.production
.envrc
!.env.example
frontend/.env
!frontend/.env.example

# Firebase service account keys and other secrets (CRITICAL - DO NOT COMMIT)
secrets/
**/service-account*.json
**/firebase-adminsdk*.json
**/*credentials*.json
!.vscode/settings.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.spyderproject
.spyproject
.ropeproject
.abstra/
.cursorignore
.cursorindexingignore

# ── Gemini AI agent artifacts ─────────────────────────────────────────────────
.gemini/

# ── Misc Python tools ────────────────────────────────────────────────────────
.scrapy
.pybuilder/
# Maven/Java target directory (using specific path to avoid catching other target folders)
/target/
/site
.pypirc
celerybeat-schedule
celerybeat.pid
*.sage.py
*.mo
*.pot
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
# Flask instance folder (using specific path to avoid catching other instance folders)
/instance/
.webassets-cache
docs/_build/
marimo/_static/
marimo/_lsp/
__marimo__/


# ══════════════════════════════════════════════════════════════════════════════
# CourtAccess AI specific exclusions
# ══════════════════════════════════════════════════════════════════════════════

# ── Airflow runtime directories (bind-mounted in Docker, never committed) ─────
# Only ignore Airflow-specific directories, not source code folders
/logs/
/plugins/
/config/
airflow.cfg
airflow.db
unittests.cfg

# ── PostgreSQL local database data ────────────────────────────────────────────
.pgdata/
db/pgdata/

# ── DVC — local remote storage & internal files ───────────────────────────────
.dvc/tmp/
.dvc/cache/
.dvc/config.local
dvc_storage/

# ── GCP resources ────────────────────────────────────────────────────────────
# GCP configuration directory (contains service account keys)
.config/

# ── DVC-tracked data (actual data ignored, pointer files allowed) ─────────────
courtaccess/data/*
!courtaccess/data/*.dvc

# ── Downloaded court forms (DVC-tracked, NOT git) ─────────────────────────────
/forms/

# ── AI Model weights (tracked by DVC, NOT Git) ───────────────────────────────
models/*
!models/*.dvc
!models/.gitignore

# ── React Frontend (Vite) ─────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.eslintcache
frontend/coverage/
frontend/tsconfig.app.tsbuildinfo

# pnpm
.pnpm-store/
node_modules/

# ── Downloaded & translated PDFs (DVC-tracked, not Git) ──────────────────────
/downloads/
/temp/
docs/_build/

# ── Docker artifacts ──────────────────────────────────────────────────────────
*.tar
