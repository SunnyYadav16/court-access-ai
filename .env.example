# ══════════════════════════════════════════════════════════════════════════════
# .env.example — CourtAccess AI
# Copy to .env and fill in real values for local development.
# For production, copy to .env.production (this file is gitignore'd).
# NEVER commit .env or .env.production to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
DEBUG=true
SECRET_KEY=your-secret-key-here             # python3 -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
SIGNED_URL_EXPIRY_SECONDS=3600

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=                         # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=                         # python3 -c "import secrets; print(secrets.token_hex(32))"
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW_BASE_URL=http://airflow-apiserver:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
# Local dev: same value as POSTGRES_DB is fine (Airflow's tables are isolated by name).
# Production (Cloud SQL): set this to a SEPARATE database (e.g. airflow_metadata)
# so Airflow's ~62 metadata tables don't pollute your application schema.
AIRFLOW_DB=courtaccess                      # production: airflow_metadata
_PIP_ADDITIONAL_REQUIREMENTS=              # extra pip packages for local dev only

# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-east1
GCP_SERVICE_ACCOUNT_JSON=                   # JSON string or leave empty to use GOOGLE_APPLICATION_CREDENTIALS

# ── Cloud SQL (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_USER=courtaccess
POSTGRES_PASSWORD=courtaccess
POSTGRES_DB=courtaccess
POSTGRES_PORT=5432
POSTGRES_HOST=postgres                      # production: Cloud SQL public IP (e.g. 34.138.x.x)

# ── Redis & MLflow ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Docker Compose service-to-service networking: mlflow resolves to the mlflow container.
# For local dev outside Docker use: http://localhost:5000
# MLflow backend DB: postgresql+psycopg2://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/mlflow
# MLflow artifact store: gs://<GCS_BUCKET_MODELS>/mlflow-artifacts/
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── GCS Buckets ───────────────────────────────────────────────────────────────
GCS_BUCKET_UPLOADS=your-project-uploads
GCS_BUCKET_TRANSLATED=your-project-translated
GCS_BUCKET_FORMS=your-project-forms
GCS_BUCKET_MODELS=your-project-models

# ── Vertex AI (Llama 4) ───────────────────────────────────────────────────────
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=your-location
VERTEX_LEGAL_LLM_MODEL=vertex-llama-model
LEGAL_VERIFY_TIMEOUT=5.0

# ── Model Configuration & Feature Flags ──────────────────────────────────────
USE_REAL_CLASSIFICATION=false
USE_REAL_TRANSLATION=false
USE_VERTEX_LEGAL_REVIEW=false
USE_REAL_OCR=false
USE_REAL_HANDWRITING_OCR=false
USE_REAL_SPEECH=false
WHISPER_MODEL=large-v3
NLLB_MODEL=facebook/nllb-200-distilled-1.3B
VAD_SPEECH_THRESHOLD=0.5
PIPER_VOICES_DIR=
SESSION_RECORDINGS_DIR=/tmp/courtaccess/sessions
TURN_GRACE_A_MS=2000
TURN_GRACE_B_MS=1000
TTS_LOCKOUT_BUFFER_MS=200

NLLB_MODEL_PATH=/opt/airflow/models/nllb-200-distilled-1.3B-ct2
QWEN_VL_MODEL_PATH=/opt/airflow/models/qwen2.5-vl
WHISPER_MODEL_PATH=/opt/airflow/models/whisper-large-v3
PIPER_TTS_ES_PATH=/opt/airflow/models/piper-tts-es
PIPER_TTS_PT_PATH=/opt/airflow/models/piper-tts-pt
PIPER_TTS_EN_PATH=/opt/airflow/models/piper-tts-en
SILERO_VAD_MODEL_PATH=/opt/airflow/models/silero-vad-v4/silero_vad.jit.pt

# ── Auth (GCIP / Firebase) ────────────────────────────────────────────────────
GCIP_API_KEY=                               # Firebase Console → Project Settings → General → Your apps
GCIP_AUTH_DOMAIN=your-project.firebaseapp.com
GCIP_PROJECT_ID=your-project-id
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── RBAC Bootstrap ────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com

# ── Artifact Registry ─────────────────────────────────────────────────────────
ARTIFACT_REGISTRY=us-east1-docker.pkg.dev/your-project-id/courtaccess-repo

# ── Local Dev Only (not used in production) ───────────────────────────────────
# Path to Firebase Admin SDK service account JSON (download from Firebase Console)
# In production on GCE/GKE, Workload Identity provides credentials automatically.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-project-firebase-adminsdk.json

# ── Migration control ─────────────────────────────────────────────────────────
# Set to true when a separate process owns schema migrations (e.g. a K8s
# initContainer or CI step). Leave false for local dev — docker-compose
# ordering via airflow-init already prevents the startup race.
SKIP_API_MIGRATIONS=false

# ── Monitoring & Bias Thresholds ──────────────────────────────────────────────
BIAS_UNDERSERVED_THRESHOLD=0.5
BIAS_TRANSLATION_COVERAGE_MIN=20.0
BIAS_LANGUAGE_GAP_MAX=30.0

# ── Model & Extraction Overrides ──────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.35
VERTEX_MAX_RETRIES=3
TRANSLATION_HALLUCINATION_RATIO_MAX=2.5
TRANSLATION_HALLUCINATION_RATIO_MIN=0.1

# ── Anomaly Detection Thresholds ──────────────────────────────────────────────
ANOMALY_FORM_DROP_PCT=20.0
ANOMALY_MASS_NEW_FORMS=50
ANOMALY_DOWNLOAD_FAIL_PCT=10.0
ANOMALY_MIN_PDF_SIZE_BYTES=1024
ANOMALY_MAX_PDF_SIZE_BYTES=52428800
ANOMALY_SCHEMA_ERRORS=0

# ── Scraper Tuning ────────────────────────────────────────────────────────────
SCRAPER_BATCH_SIZE=10
SCRAPER_BATCH_SLEEP_SEC=15
SCRAPER_PRE_DOWNLOAD_SLEEP=60
SCRAPER_REQUEST_TIMEOUT=30

# ── Processor Tuning ──────────────────────────────────────────────────────────
PDF_RENDER_DPI=300
VALIDATION_CONFIDENCE_THRESHOLD=0.85
