# ══════════════════════════════════════════════════════════════════════════════
# .env.example — CourtAccess AI environment variables
# Copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
DEBUG=true
SECRET_KEY=                                  # python3 -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8000

# ── Database (Cloud SQL / PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://courtaccess:courtaccess@localhost:5432/courtaccess
SYNC_DATABASE_URL=postgresql+psycopg2://courtaccess:courtaccess@localhost:5433/courtaccess
POSTGRES_USER=courtaccess
POSTGRES_PASSWORD=courtaccess
POSTGRES_DB=courtaccess

# ── Google Cloud ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-east1

# ── Firebase Admin SDK (Backend Authentication) ───────────────────────────────
# Required for verifying Firebase ID tokens on the backend.
# On GKE: Workload Identity provides credentials automatically (no config needed)
# Locally: Download service account JSON from Firebase Console → Project Settings
#          → Service Accounts → Generate New Private Key
# The service account must have "Firebase Authentication Admin" role.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-project-firebase-adminsdk.json

# ── GCS Buckets ────────────────────────────────────────────────────────────────
GCS_BUCKET_UPLOADS=your-project-uploads      # User-uploaded PDFs (auto-deleted 24h)
GCS_BUCKET_TRANSLATED=your-project-translated # Translated output PDFs (auto-deleted 24h)
GCS_BUCKET_FORMS=your-project-forms          # Pre-translated government forms (permanent)
GCS_BUCKET_MODELS=your-project-models        # DVC-tracked model weights (permanent)

# ── Signed URL Expiry ──────────────────────────────────────────────────────────
SIGNED_URL_EXPIRY_SECONDS=3600              # 1 hour

# ── Vertex AI (Llama 4) ───────────────────────────────────────────────────────
VERTEX_PROJECT=your-project-id
VERTEX_LOCATION=us-east5
LEGAL_LLM_MODEL=llama-4-scout-17b-16e-instruct-maas
LEGAL_VERIFY_TIMEOUT=5.0

# ── Auth (GCIP / Firebase) ────────────────────────────────────────────────────
GCIP_API_KEY=                               # Get from Firebase Console → Project Settings → General
GCIP_AUTH_DOMAIN=your-project.firebaseapp.com
GCIP_PROJECT_ID=your-project-id

# ── RBAC Bootstrap ────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com              # Comma-separated list of admin emails

# ── Artifact Registry ─────────────────────────────────────────────────────────
ARTIFACT_REGISTRY=us-east1-docker.pkg.dev/your-project-id/courtaccess-repo

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=courtaccess-models

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=                         # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=                         # python3 -c "import secrets; print(secrets.token_hex(32))"
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── DVC ───────────────────────────────────────────────────────────────────────
DVC_REMOTE=gs://your-project-models/dvc-cache
