# ══════════════════════════════════════════════════════════════════════════════
# .env.example — CourtAccess AI environment variables
# Copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
DEBUG=true
SECRET_KEY=                                  # python3 -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database (Cloud SQL / PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://courtaccess:courtaccess@localhost:5432/courtaccess
POSTGRES_USER=courtaccess
POSTGRES_PASSWORD=courtaccess
POSTGRES_DB=courtaccess

# ── Google Cloud ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=             # Path to service account JSON (local only)

# ── GCS Buckets ────────────────────────────────────────────────────────────────
GCS_BUCKET_UPLOADS=courtaccess-uploads      # User-uploaded PDFs (auto-deleted 24h)
GCS_BUCKET_TRANSLATED=courtaccess-translated # Translated output PDFs (auto-deleted 24h)
GCS_BUCKET_FORMS=courtaccess-forms          # Pre-translated government forms (permanent)
GCS_BUCKET_MODELS=courtaccess-models        # DVC-tracked model weights (permanent)

# ── Signed URL Expiry ──────────────────────────────────────────────────────────
SIGNED_URL_EXPIRY_SECONDS=3600              # 1 hour

# ── AI / LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=                               # https://console.groq.com
GROQ_MODEL=llama-3.1-8b-instant

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=courtaccess-models

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=                         # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=                         # python3 -c "import secrets; print(secrets.token_hex(32))"
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── DVC ───────────────────────────────────────────────────────────────────────
DVC_REMOTE=gs://courtaccess-models/dvc-cache
